{
  "name": "webchat-3",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @webchat/server dev & pnpm --filter @webchat/web dev",
    "dev:server": "pnpm --filter @webchat/server dev",
    "dev:web": "pnpm --filter @webchat/web dev",
    "build": "pnpm --filter @webchat/shared build && pnpm --filter @webchat/server build && pnpm --filter @webchat/web build",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,mjs,cjs,json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.0"
  }
}
